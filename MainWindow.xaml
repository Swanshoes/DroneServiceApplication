<Window x:Class="DroneServiceApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DroneServiceApplication"
        mc:Ignorable="d"
        Title="Icarus Drone Service Application"
        Height="650"
        Width="1530"
        ResizeMode="NoResize">

    <Grid Background="#FFB7A7A7">

        <Label Content="Icarus Drone Servicing"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="0,15,0,0"
               FontSize="18"
               FontWeight="Bold"
               Foreground="#FF651E1E"/>

        <!-- Service Entry Panel -->
        <Border HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Width="350"
        Height="560"
        Margin="23,59,0,0"
        Background="#FFB7A7A7"
        BorderBrush="Black"
        BorderThickness="1"
        Padding="10">

            <StackPanel Orientation="Vertical">

                <Label Content="Enter Service Details"
               FontSize="14"
               FontWeight="Bold"/>

                <Label Content="Client Name"/>
                <TextBox x:Name="ClientNameTB"
                 Height="25"
                 FontSize="16"
                 Foreground="#FF989090"/>

                <Label Content="Drone Model"/>
                <TextBox x:Name="DroneModelTB"
                 Height="25"
                 FontSize="16"
                 Foreground="#FF989090"/>

                <Label Content="Service Problem"/>
                <TextBox x:Name="ServiceProblemTB"
                 Height="119"
                 FontSize="16"
                 Foreground="#FF989090"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"/>

                <Label Content="Service Price"/>
                <TextBox x:Name="ServiceCostTB"
                 Height="25"
                 FontSize="16"
                 Foreground="#FF989090"
                 PreviewTextInput="ServiceCostTB_PreviewTextInput"
                 DataObject.Pasting="ServiceCostTB_Pasting"/>

                <Label Content="Service Tag"/>

                <TextBox x:Name="ServiceTagTB"
                    Height="25"
                    FontSize="16"
                    IsReadOnly="True"
                    Background="#FFE6E6E6"
                    Foreground="Black"
                    TextAlignment="Center"/>

                <Label Content="Service Type"/>

                <StackPanel Orientation="Horizontal"
                    Margin="5,0,0,0">
                    <RadioButton x:Name="RegularServiceRB"
                         Content="Regular"
                         GroupName="ServiceType"
                         IsChecked="True"
                         Margin="0,0,30,0"/>

                    <RadioButton x:Name="ExpressServiceRB"
                         Content="Express"
                         GroupName="ServiceType"/>
                </StackPanel>

                <Button x:Name="AddToQueueBTN"
                Content="Add to Queue"
                Height="40"
                Margin="0,25,0,0"
                Background="#FF95CC7C" Click="AddToQueueBTN_Click"/>

                <Button x:Name="ClearInputsBTN"
                Content="Clear Inputs"
                Height="40"
                Margin="0,10,0,0"
                Background="#FFCC8B7C" Click="ClearInputsBTN_Click"/>

            </StackPanel>
        </Border>

        <!-- Service Queue Panel -->
        <Border HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Width="730"
        Height="543"
        Margin="0,59,0,0"
        Background="#FFB7A7A7"
        BorderBrush="Black"
        BorderThickness="1"
        Padding="10">

            <StackPanel Orientation="Vertical">

                <Label Content="Service Queues"
               FontSize="14"
               FontWeight="Bold"
               Height="27"/>

                <!-- Regular Service Queue -->
                <Label Content="Regular Service Queue"
               FontSize="13"
               FontWeight="SemiBold"
               Margin="0,5,0,0"/>

                <ListView x:Name="RegularQueueLV"
                  Height="170"
                  Margin="0,0,0,8" SelectionChanged="RegularQueueLV_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Tag"
                                    DisplayMemberBinding="{Binding ServiceTag}"
                                    Width="80"/>

                            <GridViewColumn Header="Client"
                                    DisplayMemberBinding="{Binding ClientName}"
                                    Width="120"/>

                            <GridViewColumn Header="Model"
                                    DisplayMemberBinding="{Binding DroneModel}"
                                    Width="120"/>

                            <GridViewColumn Header="Problem"
                                    DisplayMemberBinding="{Binding ServiceProblem}"
                                    Width="260"/>

                            <GridViewColumn Header="Cost"
                                    DisplayMemberBinding="{Binding ServiceCost}"
                                    Width="90"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Button x:Name="DequeueRegularBTN"
                Content="Dequeue Regular Service"
                Height="35"
                Margin="0,0,0,10"
                Background="#FF95CC7C" Click="DequeueRegularBTN_Click"/>

                <!-- Express Service Queue -->
                <Label Content="Express Service Queue"
               FontSize="13"
               FontWeight="SemiBold"/>

                <ListView x:Name="ExpressQueueLV"
                  Height="170"
                  Margin="0,0,0,8" SelectionChanged="ExpressQueueLV_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Tag"
                                    DisplayMemberBinding="{Binding ServiceTag}"
                                    Width="80"/>

                            <GridViewColumn Header="Client"
                                    DisplayMemberBinding="{Binding ClientName}"
                                    Width="120"/>

                            <GridViewColumn Header="Model"
                                    DisplayMemberBinding="{Binding DroneModel}"
                                    Width="120"/>

                            <GridViewColumn Header="Problem"
                                    DisplayMemberBinding="{Binding ServiceProblem}"
                                    Width="260"/>

                            <GridViewColumn Header="Cost"
                                    DisplayMemberBinding="{Binding ServiceCost}"
                                    Width="90"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Button x:Name="DequeueExpressBTN"
                Content="Dequeue Express Service"
                Height="35"
                Background="#FF95CC7C" Click="DequeueExpressBTN_Click"/>

            </StackPanel>
        </Border>

        <!-- Completed Services Panel -->
        <Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Width="350"
                Height="560"
                Margin="1154,59,0,0"
                Background="#FFB7A7A7"
                BorderBrush="Black"
                BorderThickness="1"
                Padding="10">

            <StackPanel Orientation="Vertical">

                <Label Content="Completed Services"
                       FontSize="14"
                       FontWeight="Bold"/>

                <ListBox x:Name="FinishedServicesLB"
                         MouseDoubleClick="FinishedServicesLB_MouseDoubleClick"
                         Height="445"/>

                <Button x:Name="MarkCompletedBTN"
                        Content="Mark as Completed"
                        Height="40"
                        Margin="0,15,0,0"
                        Background="#FF95CC7C" Click="MarkCompletedBTN_Click"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>